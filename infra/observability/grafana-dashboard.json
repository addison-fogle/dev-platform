{
  "title": "Dev Platform Overview",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "title": "API Request Rate",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count[5m]))"
        }
      ]
    },
    {
      "title": "Deployment Status Transitions",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (from, to) (rate(deployments_status_transitions_total[5m]))"
        }
      ]
    },
    {
      "title": "Rollbacks Created",
      "type": "timeseries",
      "targets": [
        {
          "expr": "increase(deployments_rollback_created_total[1h])"
        }
      ]
    },
    {
      "title": "API Latency p95",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket[5m])) by (le))"
        }
      ]
    }
  ]
}
